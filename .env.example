# API Keys Configuration Guide
# Copy this file to .env and replace the placeholder values with your actual API keys

# Email Service (Resend) - https://resend.com
# Sign up for free account, get API key from dashboard
RESEND_API_KEY="re_YOUR_ACTUAL_API_KEY_HERE"
RESEND_FROM_EMAIL="Your Name <your-verified-email@yourdomain.com>"

# SMS Service (Africa's Talking) - https://africastalking.com
# Sign up, create app, get credentials from sandbox
AFRICA_TALKING_USERNAME="YOUR_USERNAME"  # Use "sandbox" for testing
AFRICA_TALKING_API_KEY="atsk_YOUR_API_KEY_HERE"

# CRM (HubSpot) - https://developers.hubspot.com
# Create app, get private app access token
HUBSPOT_ACCESS_TOKEN="pat-na1-YOUR_ACCESS_TOKEN_HERE"

# LLM Provider (OpenRouter) - https://openrouter.ai
# Sign up, add credits, get API key
OPENROUTER_API_KEY="sk-or-v1-YOUR_API_KEY_HERE"

# Observability (Langfuse) - https://langfuse.com
# Create project, get public/secret key pair
LANGFUSE_PUBLIC_KEY="pk-lf-YOUR_PUBLIC_KEY_HERE"
LANGFUSE_SECRET_KEY="sk-lf-YOUR_SECRET_KEY_HERE"

# Calendar Booking (Cal.com) - https://cal.com
# Self-host or use cloud, get API credentials
CALCOM_API_URL="https://api.cal.com/v1"  # Or your self-hosted URL
CALCOM_API_KEY="cal_YOUR_API_KEY_HERE"

# Webhook Configuration
# Use ngrok for local development: ngrok http 8000
WEBHOOK_BASE_URL="https://your-domain.com"  # Or ngrok URL for testing

# Model Configuration (for LLM calls)
DEV_MODEL="qwen/qwen-2.5-72b-instruct"  # OpenRouter model name
EVAL_MODEL="anthropic/claude-3-5-sonnet"  # For evaluation
TEMPERATURE=0.7

# Budget Limits
MAX_COST_PER_LEAD=5.0  # Maximum $ to spend per lead
DAILY_VOICE_BUDGET=3.0  # Daily budget for voice/SMS

# Optional: Database Configuration
DATABASE_URL="postgresql://user:password@localhost/conversion_engine"
REDIS_URL="redis://localhost:6379"

# Optional: Additional Services
# CRUNCHBASE_API_KEY="YOUR_KEY"  # For company enrichment
# CLEARBIT_API_KEY="YOUR_KEY"  # Alternative enrichment
# TWILIO_ACCOUNT_SID="YOUR_SID"  # Alternative SMS provider
# TWILIO_AUTH_TOKEN="YOUR_TOKEN"